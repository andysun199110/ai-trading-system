   color statusColor = g_IsConnected ? g_ColorSuccess : g_ColorError;
   CreateLabel(prefix + "status", g_PanelX + 5, g_PanelY + 25, 0, 0, "Status: " + status, statusColor, 10);
   
   // Mode
