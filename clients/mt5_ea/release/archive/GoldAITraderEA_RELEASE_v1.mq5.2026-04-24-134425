   string account = IntegerToString(AccountInfoInteger(ACCOUNT_LOGIN));
   CreateLabel(prefix + "account", g_PanelX + 5, g_PanelY + 55, 0, 0, "Account: " + account, g_ColorText, 10);
   
   // Last poll
   string lastPoll = g_LastPollTime > 0 ? TimeToString(g_LastPollTime, TIME_MINUTES|TIME_SECONDS) : "Never";
   CreateLabel(prefix + "poll", g_PanelX + 5, g_PanelY + 70, 0, 0, "Last Poll: " + lastPoll, g_ColorText, 10);
   
   // Position info
   if(g_PositionLots > 0)
   {
      string posType = (g_PositionType == POSITION_TYPE_BUY) ? "BUY" : "SELL";
      CreateLabel(prefix + "pos", g_PanelX + 5, g_PanelY + 90, 0, 0, 
                  "Position: " + posType + " " + DoubleToString(g_PositionLots, 2) + 
                  " | P/L: $" + DoubleToString(g_PositionProfit, 2), 
                  g_PositionProfit >= 0 ? g_ColorSuccess : g_ColorError, 10);
   }
   else
   {
      CreateLabel(prefix + "pos", g_PanelX + 5, g_PanelY + 90, 0, 0, "Position: None", g_ColorText, 10);
   }
   
   // Last signal
   if(g_LastSignalId != "")
   {
      CreateLabel(prefix + "signal", g_PanelX + 5, g_PanelY + 110, 0, 0, 
                  "Last: " + g_LastSignalAction + " (" + g_LastSignalId + ")", g_ColorText, 9);
   }
   
   // Execution result
   if(g_LastExecutionResult != "")
   {
      color resultColor = StringFind(g_LastExecutionResult, "SUCCESS") != -1 ? g_ColorSuccess : g_ColorError;
      CreateLabel(prefix + "exec", g_PanelX + 5, g_PanelY + 125, 0, 0, g_LastExecutionResult, resultColor, 9);
   }
}

//+------------------------------------------------------------------+
//| Helper: Create label object                                      |
//+------------------------------------------------------------------+
void CreateLabel(string name, int x, int y, int width, int height, string text, color clr, 
                 color bgColor = clrNONE, int fontSize = 10, bool bold = false)
{
   if(ObjectFind(0, name) < 0)
   {
      ObjectCreate(0, name, OBJ_LABEL, 0, 0, 0);
      ObjectSetInteger(0, name, OBJPROP_CORNER, CORNER_LEFT_UPPER);
      ObjectSetInteger(0, name, OBJPROP_XDISTANCE, x);
      ObjectSetInteger(0, name, OBJPROP_YDISTANCE, y);
   }
   
   ObjectSetInteger(0, name, OBJPROP_COLOR, clr);
   ObjectSetInteger(0, name, OBJPROP_FONTSIZE, fontSize);
   ObjectSetString(0, name, OBJPROP_TEXT, text);
   ObjectSetString(0, name, OBJPROP_FONT, bold ? "Arial Bold" : "Arial");
}

//+------------------------------------------------------------------+
//| Helper: Delete all objects with prefix                           |
//+------------------------------------------------------------------+
void DeleteAllObjects(long chart_id, string prefix)
{
   int total = ObjectsTotal(chart_id, 0, OBJ_LABEL);
   for(int i = total - 1; i >= 0; i--)
   {
      string name = ObjectName(chart_id, i, 0, OBJ_LABEL);
      if(StringFind(name, prefix) == 0)
      {
         ObjectDelete(chart_id, name);
      }
   }
}
