   PrintFormat("[GoldAI] ═══════════════════════════════════════════");
   PrintFormat("[GoldAI] API Endpoint: %s", Inp_ApiBaseUrl);
   PrintFormat("[GoldAI] Operation Mode: %s", Inp_ShadowMode ? "🔒 SHADOW (No Execution)" : "⚠️ LIVE (Real Trading)");
   PrintFormat("[GoldAI] Trading Allowed: %s", Inp_AllowTrading ? "⚠️ YES" : "✅ NO (Safe)");
   PrintFormat("[GoldAI] Account: %d @ %s", AccountInfoInteger(ACCOUNT_LOGIN), AccountInfoString(ACCOUNT_SERVER));
   PrintFormat("[GoldAI] Max Lot Cap: %.2f", Inp_MaxLotCap);
   
   // Validate critical parameters
   if(Inp_ApiBaseUrl == "https://your-api-domain.com/api/v1" || Inp_ApiBaseUrl == "")
   {
      Print("[GoldAI] ⚠️ WARNING: API Base URL not configured! Please set Inp_ApiBaseUrl in parameters.");
   }
   
   if(Inp_LicenseKey == "")
   {
      Print("[GoldAI] ⚠️ WARNING: License Key not configured! Authentication will fail.");
   }
   
   // Restore local state
   RestoreLocalState();
   
   // Initial authentication
   if(!Authenticate())
   {
      Print("[GoldAI] Initial auth failed, will retry on first poll");
      g_SessionToken = "";
   }
   else
   {
      Print("[GoldAI] ✅ Initial authentication successful");
   }
   
   // Set timer
   EventSetTimer(Inp_PollIntervalSec);
   
   Print("[GoldAI] ═══════════════════════════════════════════");
   Print("[GoldAI] Initialization complete - Ready for operation");
   Print("[GoldAI] ═══════════════════════════════════════════");
   return(INIT_SUCCEEDED);
}

//+------------------------------------------------------------------+
//| Expert deinitialization function                                 |
//+------------------------------------------------------------------+
void OnDeinit(const int reason)
{
   EventKillTimer();
   DeleteAllObjects(0, "GoldAI_");
   
   string reasonText = "";
   switch(reason)
   {
      case INIT_REMOVE: reasonText = "Removed from chart"; break;
      case INIT_RECOMPILE: reasonText = "Recompiled"; break;
      case INIT_CHARTCHANGE: reasonText = "Chart changed"; break;
      case INIT_PARAMETERS: reasonText = "Parameters changed"; break;
      case INIT_TEMPLATE: reasonText = "Template changed"; break;
      default: reasonText = "Unknown"; break;
   }
   
   PrintFormat("[GoldAI] Deinitialized: %s", reasonText);
}

