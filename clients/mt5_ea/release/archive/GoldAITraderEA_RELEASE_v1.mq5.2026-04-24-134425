//+------------------------------------------------------------------+
//| Timer function - Main polling loop                               |
//+------------------------------------------------------------------+
void OnTimer()
{
   // Ensure we have a session token
   if(g_SessionToken == "")
   {
      if(!Authenticate())
      {
         Print("[GoldAI] Auth failed, will retry on next poll");
         return;
      }
   }
   
   // Send heartbeat to keep session alive
   Heartbeat();
   
   // Poll for trading signals from server
   PollSignals();
   
   // Supervise any open positions
   SuperviseOpenPositions();
}

//+------------------------------------------------------------------+
//| Restore local state from file                                    |
//+------------------------------------------------------------------+
void RestoreLocalState()
{
   // Read processed signals file to avoid duplicate executions
   if(FileIsExist(g_ProcessedSignalsFile))
   {
      Print("[GoldAI] 📁 Restored processed signals ledger");
   }
   else
   {
      // Create new file with header
      int handle = FileOpen(g_ProcessedSignalsFile, FILE_WRITE|FILE_CSV);
      if(handle != INVALID_HANDLE)
      {
         FileWrite(handle, "timestamp,signal_id,action,symbol,lot_size,status");
         FileClose(handle);
         Print("[GoldAI] 📄 Created new processed signals ledger");
      }
   }
}

//+------------------------------------------------------------------+
//| Authenticate with API server                                     |
//+------------------------------------------------------------------+
bool Authenticate()
{
   if(Inp_LicenseKey == "")
   {
      Print("[GoldAI] ❌ Cannot authenticate: License Key is empty");
      return false;
   }
   
   string url = Inp_ApiBaseUrl + "/auth";
   string headers = "Content-Type: application/json\r\n";
   string post_data = "{\"license_key\":\"" + Inp_LicenseKey + "\",\"account_login\":\"" + 
                      IntegerToString(AccountInfoInteger(ACCOUNT_LOGIN)) + "\",\"account_server\":\"" + 
                      AccountInfoString(ACCOUNT_SERVER) + "\"}";
   
   int timeout = 30000; // 30 seconds
   int http_code = 0;
   
   string response = WebRequest("POST", url, headers, timeout, post_data, http_code);
   
   g_LastHttpCode = http_code;
   
   if(http_code == 200)
   {
      // Extract session token from response
      // Expected format: {"session_token":"xxx","expires_in":3600}
      int token_start = StringFind(response, "\"session_token\":\"");
      if(token_start != -1)
      {
         token_start += 17; // Length of "\"session_token\":\""
         int token_end = StringFind(response, "\"", token_start);
         if(token_end != -1)
         {
            g_SessionToken = StringSubstr(response, token_start, token_end - token_start);
            PrintFormat("[GoldAI] ✅ Auth successful - Session token received");
            g_IsConnected = true;
            return true;
         }
      }
      
      Print("[GoldAI] ⚠️ Auth response parsing failed");
      return false;
   }
   else if(http_code == 401 || http_code == 403)
   {
      PrintFormat("[GoldAI] ❌ Auth failed: HTTP %d - Invalid credentials or license", http_code);
      g_IsConnected = false;
      return false;
   }
   else if(http_code == 0)
   {
      PrintFormat("[GoldAI] ❌ Auth failed: Cannot connect to %s", url);
      Print("[GoldAI] ⚠️ Check: 1) Internet connection 2) WebRequest whitelist 3) API URL");
      g_IsConnected = false;
      return false;
   }
   else
   {
      PrintFormat("[GoldAI] ❌ Auth failed: HTTP %d", http_code);
      g_IsConnected = false;
      return false;
   }
}

//+------------------------------------------------------------------+
//| Send heartbeat to maintain session                               |
//+------------------------------------------------------------------+
void Heartbeat()
{
   if(g_SessionToken == "") return;
   
   string url = Inp_ApiBaseUrl + "/heartbeat";
   string headers = "Content-Type: application/json\r\nAuthorization: Bearer " + g_SessionToken + "\r\n";
   string post_data = "{\"account_login\":\"" + IntegerToString(AccountInfoInteger(ACCOUNT_LOGIN)) + 
                      "\",\"account_server\":\"" + AccountInfoString(ACCOUNT_SERVER) + "\"," +
                      "\"shadow_mode\":" + (Inp_ShadowMode ? "true" : "false") + "}";
   
   int timeout = 10000;
   int http_code = 0;
   
   string response = WebRequest("POST", url, headers, timeout, post_data, http_code);
   
   if(http_code == 200)
   {
      g_LastSuccessfulPoll = TimeCurrent();
      Print("[GoldAI] 💓 Heartbeat sent successfully");
   }
   else
   {
      PrintFormat("[GoldAI] ⚠️ Heartbeat failed: HTTP %d", http_code);
   }
}

//+------------------------------------------------------------------+
//| Poll for trading signals from server                             |
//+------------------------------------------------------------------+
void PollSignals()
{
   if(g_SessionToken == "") return;
   
   string url = Inp_ApiBaseUrl + "/signals/poll";
   string headers = "Content-Type: application/json\r\nAuthorization: Bearer " + g_SessionToken + "\r\n";
   string post_data = "{\"account_login\":\"" + IntegerToString(AccountInfoInteger(ACCOUNT_LOGIN)) + 
                      "\",\"account_server\":\"" + AccountInfoString(ACCOUNT_SERVER) + "\"," +
                      "\"last_signal_id\":\"" + g_LastSignalId + "\"," +
                      "\"symbol\":\"XAUUSD\"," +
                      "\"shadow_mode\":" + (Inp_ShadowMode ? "true" : "false") + "}";
   
   int timeout = 30000;
   int http_code = 0;
   
   string response = WebRequest("POST", url, headers, timeout, post_data, http_code);
   
   g_LastHttpCode = http_code;
   g_LastPollTime = TimeCurrent();
   
   if(http_code == 200)
   {
      g_LastSuccessfulPoll = TimeCurrent();
      
      // Check if there's a new signal
      if(StringFind(response, "\"signal_id\"") != -1)
      {
         ProcessSignal(response);
      }
      else
      {
         Print("[GoldAI] 📡 Poll: No new signals");
      }
   }
   else if(http_code == 401 || http_code == 403)
   {
      Print("[GoldAI] ❌ Poll failed: Session expired, re-authenticating...");
      g_SessionToken = "";
      Authenticate();
   }
   else
   {
      PrintFormat("[GoldAI] ⚠️ Poll failed: HTTP %d", http_code);
   }
}

//+------------------------------------------------------------------+
//| Process trading signal from server                               |
//+------------------------------------------------------------------+
void ProcessSignal(string response)
{
   // Extract signal details
   // Expected format: {"signal_id":"xxx","action":"BUY/SELL/CLOSE","lot_size":0.01,"symbol":"XAUUSD",...}
   
   int signalIdStart = StringFind(response, "\"signal_id\":\"");
   if(signalIdStart == -1) return;
   signalIdStart += 13;
   int signalIdEnd = StringFind(response, "\"", signalIdStart);
   string signal_id = StringSubstr(response, signalIdStart, signalIdEnd - signalIdStart);
   
   // Check if already processed
   if(IsSignalProcessed(signal_id))
   {
      PrintFormat("[GoldAI] ⏭️ Signal %s already processed, skipping", signal_id);
      return;
   }
   
   // Extract action
   int actionStart = StringFind(response, "\"action\":\"");
   if(actionStart == -1) return;
   actionStart += 10;
   int actionEnd = StringFind(response, "\"", actionStart);
   string action = StringSubstr(response, actionStart, actionEnd - actionStart);
   
   // Extract lot size
   double lot_size = Inp_DefaultLotSize;
   int lotStart = StringFind(response, "\"lot_size\":");
   if(lotStart != -1)
   {
      lotStart += 11;
      int lotEnd = StringFind(response, ",", lotStart);
      if(lotEnd == -1) lotEnd = StringFind(response, "}", lotStart);
      if(lotEnd != -1)
      {
         string lot_str = StringSubstr(response, lotStart, lotEnd - lotStart);
         lot_size = StringToDouble(lot_str);
      }
   }
   
   // Apply lot cap
   if(lot_size > Inp_MaxLotCap)
   {
      PrintFormat("[GoldAI] ⚠️ Lot size %.2f exceeds cap %.2f, using cap", lot_size, Inp_MaxLotCap);
      lot_size = Inp_MaxLotCap;
   }
   
   PrintFormat("[GoldAI] 📊 New signal: %s - Action: %s, Lots: %.2f", signal_id, action, lot_size);
   
   // Execute signal
   bool executed = false;
   
   if(action == "BUY" || action == "SELL")
   {
      if(Inp_ShadowMode || !Inp_AllowTrading)
      {
         PrintFormat("[GoldAI] 🔒 SHADOW MODE: Would execute %s %.2f lots (NOT EXECUTED)", action, lot_size);
         executed = true; // Consider "executed" for logging purposes
      }
      else
      {
         executed = ExecuteTrade(action, lot_size);
      }
   }
   else if(action == "CLOSE")
   {
      if(Inp_ShadowMode || !Inp_AllowTrading)
      {
         PrintFormat("[GoldAI] 🔒 SHADOW MODE: Would CLOSE position (NOT EXECUTED)");
         executed = true;
      }
      else
      {
         executed = ClosePosition();
      }
   }
   
   // Record processed signal
   if(executed)
   {
      RecordProcessedSignal(signal_id, action, lot_size, "EXECUTED");
      g_LastSignalId = signal_id;
      g_LastSignalAction = action;
   }
}

//+------------------------------------------------------------------+
//| Execute trade order                                              |
//+------------------------------------------------------------------+
bool ExecuteTrade(string action, double lot_size)
{
   if(!Inp_AllowTrading)
   {
      Print("[GoldAI] ❌ Trading not allowed - Inp_AllowTrading is false");
      return false;
   }
   
   ENUM_ORDER_TYPE orderType = (action == "BUY") ? ORDER_TYPE_BUY : ORDER_TYPE_SELL;
   double price = (action == "BUY") ? SymbolInfoDouble(_Symbol, SYMBOL_ASK) : SymbolInfoDouble(_Symbol, SYMBOL_BID);
   
   MqlTradeRequest request = {};
   MqlTradeResult result = {};
   
   request.action = TRADE_ACTION_DEAL;
   request.symbol = _Symbol;
   request.volume = lot_size;
   request.type = orderType;
   request.price = price;
   request.sl = (orderType == ORDER_TYPE_BUY) ? price - Inp_StopLossPoints * _Point : price + Inp_StopLossPoints * _Point;
   request.tp = (orderType == ORDER_TYPE_BUY) ? price + Inp_TakeProfitPoints * _Point : price - Inp_TakeProfitPoints * _Point;
   request.magic = g_MagicNumber;
   request.deviation = 10;
   request.type_filling = ORDER_FILLING_IOC;
   
   PrintFormat("[GoldAI] 🚀 Executing %s %.2f lots @ %.2f", action, lot_size, price);
   
   if(!OrderSend(request, result))
   {
      PrintFormat("[GoldAI] ❌ Order failed: %s (retcode=%d)", result.comment, result.retcode);
      g_LastExecutionResult = "FAILED: " + result.comment;
      return false;
   }
   
   if(result.retcode == TRADE_RETCODE_DONE)
   {
      PrintFormat("[GoldAI] ✅ Order executed successfully - Ticket: %d", result.order);
      g_LastExecutionResult = "SUCCESS: Ticket " + IntegerToString(result.order);
      return true;
   }
   else
   {
      PrintFormat("[GoldAI] ❌ Order rejected: retcode=%d", result.retcode);
      g_LastExecutionResult = "REJECTED: retcode " + IntegerToString(result.retcode);
      return false;
   }
}

//+------------------------------------------------------------------+
//| Close open position                                              |
//+------------------------------------------------------------------+
bool ClosePosition()
{
   if(!Inp_AllowTrading)
   {
      Print("[GoldAI] ❌ Trading not allowed - Inp_AllowTrading is false");
      return false;
   }
   
   // Find and close position
   if(!PositionSelect(_Symbol))
   {
      Print("[GoldAI] No open position to close");
      return false;
   }
   
   MqlTradeRequest request = {};
   MqlTradeResult result = {};
   
   ulong ticket = PositionGetTicket(POSITION_TICKET);
   double volume = PositionGetDouble(POSITION_VOLUME);
   ENUM_POSITION_TYPE posType = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);
   
   request.action = TRADE_ACTION_DEAL;
   request.position = ticket;
   request.symbol = _Symbol;
   request.volume = volume;
   request.type = (posType == POSITION_TYPE_BUY) ? ORDER_TYPE_SELL : ORDER_TYPE_BUY;
   request.price = (posType == POSITION_TYPE_BUY) ? SymbolInfoDouble(_Symbol, SYMBOL_BID) : SymbolInfoDouble(_Symbol, SYMBOL_ASK);
   request.deviation = 10;
   request.magic = g_MagicNumber;
   request.type_filling = ORDER_FILLING_IOC;
   
   PrintFormat("[GoldAI] 🚀 Closing position - Ticket: %d, Volume: %.2f", ticket, volume);
   
   if(!OrderSend(request, result))
   {
      PrintFormat("[GoldAI] ❌ Close failed: %s", result.comment);
      return false;
   }
   
   if(result.retcode == TRADE_RETCODE_DONE)
   {
      PrintFormat("[GoldAI] ✅ Position closed successfully");
      return true;
   }
   else
   {
      PrintFormat("[GoldAI] ❌ Close rejected: retcode=%d", result.retcode);
      return false;
   }
}

//+------------------------------------------------------------------+
//| Supervise open positions                                         |
//+------------------------------------------------------------------+
void SuperviseOpenPositions()
{
   if(!PositionSelect(_Symbol)) return;
   
   UpdatePositionInfo();
   
   // Check for protective close conditions
   if(g_ProtectiveMode && g_PositionProfit < -100) // $100 loss threshold
   {
      Print("[GoldAI] ⚠️ Protective mode: Large loss detected");
   }
}

//+------------------------------------------------------------------+
//| Update position information                                      |
//+------------------------------------------------------------------+
void UpdatePositionInfo()
{
   if(PositionSelect(_Symbol))
   {
      g_PositionLots = PositionGetDouble(POSITION_VOLUME);
      g_PositionEntryPrice = PositionGetDouble(POSITION_PRICE_OPEN);
      g_PositionSL = PositionGetDouble(POSITION_SL);
      g_PositionTP = PositionGetDouble(POSITION_TP);
      g_PositionType = (ENUM_POSITION_TYPE)PositionGetInteger(POSITION_TYPE);
      g_PositionCurrentPrice = PositionGetDouble(POSITION_PRICE_CURRENT);
      g_PositionProfit = PositionGetDouble(POSITION_PROFIT);
   }
   else
   {
      g_PositionLots = 0;
      g_PositionProfit = 0;
   }
}

//+------------------------------------------------------------------+
//| Check if signal was already processed                            |
//+------------------------------------------------------------------+
bool IsSignalProcessed(string signal_id)
{
   int handle = FileOpen(g_ProcessedSignalsFile, FILE_READ|FILE_CSV);
   if(handle == INVALID_HANDLE) return false;
   
   while(!FileIsEnding(handle))
   {
      string line = FileReadString(handle);
      if(StringFind(line, signal_id) != -1)
      {
         FileClose(handle);
         return true;
      }
   }
   
   FileClose(handle);
   return false;
}

//+------------------------------------------------------------------+
//| Record processed signal                                          |
//+------------------------------------------------------------------+
void RecordProcessedSignal(string signal_id, string action, double lot_size, string status)
{
   int handle = FileOpen(g_ProcessedSignalsFile, FILE_WRITE|FILE_READ|FILE_CSV);
   if(handle == INVALID_HANDLE) return;
   
   // Go to end of file
   FileSeek(handle, 0, SEEK_END);
   
   string timestamp = TimeToString(TimeCurrent(), TIME_DATE|TIME_SECONDS);
   FileWrite(handle, timestamp, signal_id, action, _Symbol, DoubleToString(lot_size, 2), status);
   
   FileClose(handle);
}

