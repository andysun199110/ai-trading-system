# ============================================================
# Gold AI Trading System - Stage 2 Configuration
# ============================================================
# Copy this file to .env and fill in required values.
# Required fields marked with (REQUIRED).
# ============================================================

# --- Environment ---
ENV=develop
SERVICE_NAME=api_server

# --- Database ---
DB_URL=postgresql+psycopg2://gold:gold@db:5432/gold_ai

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Security ---
JWT_SECRET=CHANGE_ME  # (REQUIRED) Generate with: openssl rand -hex 32
SESSION_TTL_MINUTES=15

# --- Strategy Versions ---
STRATEGY_VERSION=stage2
MODEL_VERSION=ai-stage2-v1
CONFIG_VERSION=2026.04.stage2

# ============================================================
# Optional Integrations
# ============================================================

# --- Telegram Notifications (Optional) ---
# Create bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- AI Provider (Optional, defaults to mock) ---
# Set ai_provider=deepseek and provide API key for real AI
AI_PROVIDER=mock  # Options: mock|deepseek
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_API_KEY=  # (REQUIRED for DeepSeek) Get from https://platform.deepseek.com/api_keys
AI_TIMEOUT_MS=10000
AI_MAX_RETRIES=3

# --- Market Data (Future, not required for stage2) ---
# MT5_CONNECTION_PATH=
# FINNHUB_API_KEY=
# TWELVE_DATA_API_KEY=
